# ============================================
# ChatBox - Support Environment Variables
# ============================================

# Database
DATABASE_URL=postgresql://chatbox:chatbox_secret@localhost:5432/chatbox_dev
DATABASE_URL_TEST=postgresql://chatbox:chatbox_secret@localhost:5432/chatbox_test

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=chatbox-uploads
S3_REGION=us-east-1

# Encryption (AES-256-GCM for channel credentials)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# App
NODE_ENV=development
API_PORT=3001
ADMIN_PORT=3000
API_URL=http://localhost:3001
ADMIN_URL=http://localhost:3000
